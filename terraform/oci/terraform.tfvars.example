# Copy this file to terraform.tfvars and fill in your values.
# Get these from: OCI Console → Identity → Compartments + Availability Domains

# Required — from OCI Console
compartment_id      = "ocid1.compartment.oc1..XXXXXXXXXX"
availability_domain = "XXXX:US-ASHBURN-AD-1"   # from Console → Compute → Instances → "Create Instance"
region              = "us-ashburn-1"            # or sa-bogota-1, sa-saopaulo-1

# Free tier (Ampere ARM — 4 OCPUs / 24 GB total free allowance)
# shape              = "VM.Standard.A1.Flex"
# shape_ocpus        = 2
# shape_memory_gbs   = 8

# Default (paid, E4 flex — use if you have credits from Oracle sponsor)
# shape              = "VM.Standard.E4.Flex"
# shape_ocpus        = 1
# shape_memory_gbs   = 4

# SSH keys — defaults to ed25519 key (what you have)
# ssh_public_key_path  = "~/.ssh/id_ed25519.pub"
# ssh_private_key_path = "~/.ssh/id_ed25519"
